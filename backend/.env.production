# backend/.env.production
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=fileuploader

DATABASE_URL=postgres://app:app@postgres:5432/fileuploader

# redis (session store) — set a strong password before deploying
REDIS_PASSWORD=change-me-in-prod
# nest connects to the redis service over the compose network
REDIS_URL=redis://:change-me-in-prod@redis:6379
